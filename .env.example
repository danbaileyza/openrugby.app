APP_NAME="Open Rugby"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database ───────────────────────────────────────────────
# Dev default is SQLite (file at database/database.sqlite).
# Production should use MySQL 8.0+ — the app has been built
# and tested against MySQL and uses enum columns that behave
# differently on other engines.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=openrugby
# DB_USERNAME=openrugby
# DB_PASSWORD=

# ─── Rugby Data Sources ─────────────────────────────────────
# API-Sports is the primary live + fixtures source. Free tier
# is 100 requests/day — rugby:sync-daily respects this limit.
RUGBY_API_SPORTS_ENABLED=true
RUGBY_API_SPORTS_KEY=your-api-sports-key-here
RUGBY_API_SPORTS_DAILY_LIMIT=100

# TheSportsDB — fallback when API-Sports is out of quota.
RUGBY_SPORTSDB_ENABLED=false
RUGBY_SPORTSDB_KEY=1

# Python rugbypy scraper — historical pro data.
RUGBY_RUGBYPY_ENABLED=true

# Kaggle — bulk historical CSV imports. Disabled by default.
RUGBY_KAGGLE_ENABLED=false

# ─── RAG / AI (OpenAI) ──────────────────────────────────────
# Powers the chatbot. Leaves a 503 on /api/chat if unset.
RUGBY_EMBEDDING_MODEL=openai
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Cache / Queue / Session ────────────────────────────────
# For dev the file driver is fine. In production either keep
# file (simplest, backed by local disk) or switch to redis for
# multi-server setups.
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Mail (optional) ────────────────────────────────────────
# Password resets will fail silently until this is configured.
# MAIL_MAILER=smtp
# MAIL_HOST=mail.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="no-reply@openrugby.app"
# MAIL_FROM_NAME="${APP_NAME}"
