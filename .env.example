APP_NAME=RugbyStats
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=rugby_stats
# DB_USERNAME=root
# DB_PASSWORD=

# ─── Rugby Data Sources ─────────────────────────────────────
RUGBY_API_SPORTS_ENABLED=true
RUGBY_API_SPORTS_KEY=your-api-sports-key-here
RUGBY_API_SPORTS_DAILY_LIMIT=100

RUGBY_SPORTSDB_ENABLED=false
RUGBY_SPORTSDB_KEY=1

RUGBY_RUGBYPY_ENABLED=true

RUGBY_KAGGLE_ENABLED=false

# ─── RAG / AI (OpenAI) ──────────────────────────────────────
RUGBY_EMBEDDING_MODEL=openai
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Cache / Queue ──────────────────────────────────────────
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
